{
  "name": "@seameet/mcp",
  "version": "0.2.2",
  "description": "Dual-mode MCP server for SeaMeet — let AI agents (Claude Code, Codex, Cursor) drive the desktop recorder when it's running, else read your synced cloud library and manage webhooks. Cloud mode authorizes by logging into the web app — no key copy/paste.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "seameet",
    "screen-recording",
    "meeting-recorder",
    "meeting-notes",
    "transcription",
    "ai-agent",
    "desktop-app",
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "webhooks",
    "productivity"
  ],
  "homepage": "https://app.seameet.ai/mcp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seameet-ai/seameet-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/seameet-ai/seameet-mcp/issues"
  },
  "license": "MIT",
  "author": "SeaMeet <info@seameet.ai> (https://seameet.ai)",
  "type": "module",
  "bin": {
    "seameet-mcp": "bin/seameet-mcp.js"
  },
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md",
    "manifest.json",
    "server.json",
    "glama.json",
    "smithery.yaml",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/seameet-mcp.js",
    "test": "node test/wrapper.test.js",
    "build:mcpb": "npx -y @anthropic-ai/mcpb validate manifest.json && npx -y @anthropic-ai/mcpb pack . dist/seameet.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  }
}
